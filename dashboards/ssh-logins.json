        "kind": "Panel",
        "spec": {
          "id": 2,
          "title": "Succesful SSH Login Attempts",
          "description": "Displays the total number of successful SSH login attempts",
          "links": [],
          "data": {
            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "query": {
                      "kind": "DataQuery",
                      "group": "loki",
                      "version": "v0",
                      "datasource": {
                        "name": "loki"
                      },
                      "spec": {
                        "direction": "backward",
                        "editorMode": "code",
                        "expr": "sum(count_over_time({job=\"ssh-authentication\"} |= \"sshd\" |= \"Accepted\" [$__interval]))",
                        "queryType": "range"
                      }
